# Telegram
TELEGRAM__BOT_TOKEN="000000000:XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TELEGRAM__SUPERADMIN_USERS=[]
TELEGRAM__ADMIN_USERS=[]
TELEGRAM__VIEWER_USERS=[]

# WordPress and database
WORDPRESS__PATH="/var/www/example.com"
WORDPRESS__DB_HOST="localhost"
WORDPRESS__DB_PORT=3306
WORDPRESS__DB_NAME="wordpress"
WORDPRESS__DB_USER="wordpress"
WORDPRESS__DB_PASSWORD="change-me"
WORDPRESS__CLI_RUN_AS_USER="www-data"

# Backups
BACKUP__SITE_NAME="example_com"
BACKUP__PATH_DIR="/var/backups/wordpress/example.com"
BACKUP__TMP_PATH="/tmp/telegram-wp-backup"
BACKUP__TIMEZONE="Asia/Almaty"
BACKUP__MIN_FREE_SPACE_GB=5
BACKUP__FILE_PREFIX=""

# Local bot runtime
CORE__SQLITE_PATH="bot.sqlite3"
CORE__LOGS_DIR="logs"
# user@host для примеров команд scp/rsync в /restore_path
CORE__SSH="user@server"

# System utilities
MYSQLDUMP_PATH="mysqldump"
MYSQL_PATH="mysql"
TAR_PATH="tar"
ZSTD_PATH="zstd"
DF_PATH="df"
DU_PATH="du"
CP_PATH="cp"
WP_CLI_PATH="wp"
RUNUSER_PATH="runuser"

# Disk chart
DISK_CHART__ENABLED=true
DISK_CHART__FORMAT="png"

# Scheduler
SCHEDULE__ENABLED=false
SCHEDULE__BACKUP_CRON="0 3 * * 5"
